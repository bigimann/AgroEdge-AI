# =============================================================================
# AgroEdge AI — root environment reference
# =============================================================================
# This file documents every environment variable used across the project.
# It is NOT loaded automatically by either service — it exists so you have
# one place to see all the knobs. Each service reads its own .env file:
#
#   backend/.env    (copy from backend/.env.example)
#   frontend/.env.local  (copy from frontend/.env.local.example)
#
# When running via docker-compose, these are set directly in
# docker-compose.yml instead, with the same names and meanings.
# =============================================================================

# --- Backend -----------------------------------------------------------------

# Path to the ChromaDB persistent store. Leave unset for plain venv setups —
# the backend resolves ./chroma_db relative to the project root automatically.
# Required inside Docker, where the volume is mounted at a fixed path.
CHROMA_DB_PATH=

# Base URL of the Ollama server. Leave unset for plain venv setups — the
# ollama Python library defaults to http://localhost:11434 on its own.
# Required inside Docker: the backend container cannot reach "localhost"
# on the host machine, so this must point at the host explicitly.
#   macOS / Windows Docker Desktop: http://host.docker.internal:11434
#   Linux:                          http://172.17.0.1:11434 (default bridge gateway)
OLLAMA_HOST=

# Which Ollama model to call. Defaults to qwen2.5:3b if unset.
LLM_MODEL_NAME=qwen2.5:3b

# Comma-separated list of origins allowed to call the API (CORS).
# Defaults to http://localhost:3000,http://127.0.0.1:3000 if unset.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend -----------------------------------------------------------------

# Base URL the frontend uses to reach the FastAPI backend.
# Plain dev setup: http://localhost:8000
# Docker setup:    http://localhost:8000 (browser still calls the published
#                  port on the host, not the internal Docker service name —
#                  this var is read by the browser, not by the container).
NEXT_PUBLIC_API_URL=http://localhost:8000
